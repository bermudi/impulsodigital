<script>
const chatLog = document.getElementById('chat');
const form = document.getElementById('chat-form');
const input = document.getElementById('answer');
const btn = form.querySelector('button');

const messages = [];
let turn = 0;
let finished = false;

function escapeHtml(s) {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

function formatInline(s) {
  return escapeHtml(s)
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\n/g, '<br>');
}

function addMsg(role, text, opts) {
  const div = document.createElement('div');
  div.className = 'chat-msg chat-' + role;
  if (opts && opts.report) div.className = 'chat-msg chat-report';
  div.innerHTML = formatInline(text);
  chatLog.appendChild(div);
  chatLog.scrollTop = chatLog.scrollHeight;
  return div;
}

form.addEventListener('submit', async (e) => {
  e.preventDefault();
  if (finished) return;

  const answer = input.value.trim();
  if (!answer) return;

  addMsg('user', answer);
  messages.push({ role: 'user', content: answer });
  turn++;

  input.value = '';
  btn.disabled = true;
  input.disabled = true;

  const typing = addMsg('bot', 'Pensando…');
  typing.classList.add('chat-typing');

  try {
    const res = await fetch('/api/ia', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ messages, turn }),
    });
    const data = await res.json();

    typing.remove();

    if (data.error) {
      addMsg('bot', '✗ ' + data.error);
      turn--;
      messages.pop();
    } else {
      messages.push({ role: 'assistant', content: data.text });
      addMsg('bot', data.text, { report: data.done });

      if (data.done) {
        finished = true;
        form.style.display = 'none';
        const cta = document.createElement('div');
        cta.className = 'chat-cta';
        cta.innerHTML = `¿Quieres que lo construya? Esto es justo lo que hago para negocios. <a href="/#contacto">Hablemos →</a><br><a href="/herramientas/ia/" class="chat-restart">Empezar de nuevo</a>`;
        chatLog.appendChild(cta);
        chatLog.scrollTop = chatLog.scrollHeight;
      }
    }
  } catch (err) {
    typing.remove();
    addMsg('bot', 'No pude completar la consulta. Intenta de nuevo.');
    turn--;
    messages.pop();
  } finally {
    if (!finished) {
      btn.disabled = false;
      input.disabled = false;
      input.focus();
    }
  }
});
</script>
