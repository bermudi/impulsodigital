<script>
const form = document.getElementById('sitio-form');
const result = document.getElementById('result');
const btn = form.querySelector('button');

form.addEventListener('submit', async (e) => {
  e.preventDefault();
  const url = document.getElementById('url').value.trim();
  if (!url) return;

  btn.disabled = true;
  btn.textContent = 'Diagnosticando…';
  result.innerHTML = '<div style="font-family:\'IBM Plex Mono\',monospace;font-size:0.85rem;color:var(--ink-muted);padding:1rem 0;">Cargando el sitio y revisando…</div>';

  try {
    const res = await fetch('/api/sitio', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ url }),
    });
    const data = await res.json();
    renderResult(data);
  } catch (err) {
    result.innerHTML = '<div class="result-error">No pude completar el diagnóstico. Intenta de nuevo.</div>';
  } finally {
    btn.disabled = false;
    btn.textContent = 'Diagnosticar →';
  }
});

function renderResult(d) {
  if (d.error) {
    result.innerHTML = `<div class="result-error">✗ ${d.error}</div>`;
    return;
  }

  let html = `<div class="result-summary">${d.summary}</div>`;

  html += `<div class="result-meta">URL revisada: ${d.finalUrl || d.url} · HTTP ${d.status} · ${Math.round(d.bytes/1024)} KB · ${d.loadMs}ms</div>`;

  html += '<div class="result-section">';
  html += '<div class="result-section-label">Resultado por categoría</div>';

  for (const c of d.checks) {
    const mark = c.ok === true ? '✓' : c.ok === false ? '✗' : '?';
    const markClass = c.ok === true ? 'ok' : c.ok === false ? 'fail' : 'unknown';
    html += `<div class="result-check">
      <span class="mark ${markClass}">${mark}</span>
      <span class="label">${c.label}</span>
      <span class="detail">${c.detail}</span>
    </div>`;
  }
  html += '</div>';

  html += `<div class="result-cta">
    ¿Te salieron cosas en rojo? Eso es lo que arreglo para negocios — sitios que cargan rápido, se ven bien en celular, y Google entiende. <a href="/#contacto">Hablemos →</a>
  </div>`;

  result.innerHTML = html;
}
</script>
