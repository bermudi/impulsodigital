---
layout: base.njk
title: "Verificador de correo — Impulso Digital"
description: "Pon tu dominio. Te decimos si tus correos llegan — MX, SPF, DKIM, DMARC en lenguaje claro."
permalink: /herramientas/correo/index.html
---

<div class="wrap" style="padding-top: 3rem; padding-bottom: 4rem;">
  <a href="/" style="font-family:'IBM Plex Mono',monospace;font-size:0.76rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--accent);text-decoration:none;">← Impulso Digital</a>

  <div style="margin-top: 2.5rem; max-width: 720px;">
    <div class="section-flag" style="margin-bottom: 2rem;">
      <span>§ Herramienta — Correo</span>
      <span class="page">gratis, sin registro</span>
    </div>

    <h1 style="font-family:'Playfair Display',serif;font-weight:900;font-size:clamp(2rem,5vw,3.4rem);line-height:0.95;letter-spacing:-0.02em;margin-bottom:1rem;">¿Tu correo <em style="font-style:italic;color:var(--accent);font-weight:400;">llega</em>?</h1>
    <p style="font-family:'Playfair Display',serif;font-style:italic;font-size:1.2rem;color:var(--ink-dim);line-height:1.45;margin-bottom:2rem;">Pon tu dominio (ej. miproductora.com). Verifico MX, SPF, DKIM y DMARC, y te digo en español plano si tus correos están llegando — o por qué no.</p>

    <form id="correo-form" style="display:flex;gap:0.6rem;margin-bottom:2rem;flex-wrap:wrap;">
      <input type="text" id="domain" name="domain" placeholder="miproductora.com" required style="flex:1;min-width:240px;padding:0.85rem 1rem;font-family:'IBM Plex Mono',monospace;font-size:0.95rem;border:1px solid var(--rule);background:var(--paper);color:var(--ink);border-radius:0;">
      <button type="submit" style="padding:0.85rem 1.6rem;font-family:'IBM Plex Mono',monospace;font-size:0.82rem;font-weight:500;text-transform:uppercase;letter-spacing:0.06em;background:var(--ink);color:var(--paper);border:none;cursor:pointer;border-radius:0;">Verificar →</button>
    </form>

    <div id="result" style="min-height: 4rem;"></div>
  </div>
</div>

<script>
const form = document.getElementById('correo-form');
const result = document.getElementById('result');
const btn = form.querySelector('button');

form.addEventListener('submit', async (e) => {
  e.preventDefault();
  const domain = document.getElementById('domain').value.trim();
  if (!domain) return;

  btn.disabled = true;
  btn.textContent = 'Verificando…';
  result.innerHTML = '<div style="font-family:\'IBM Plex Mono\',monospace;font-size:0.85rem;color:var(--ink-muted);padding:1rem 0;">Consultando DNS…</div>';

  try {
    const res = await fetch('/api/correo', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ domain }),
    });
    const data = await res.json();
    renderResult(data);
  } catch (err) {
    result.innerHTML = '<div style="color:var(--accent);padding:1rem 0;">No pude completar la verificación. Intenta de nuevo.</div>';
  } finally {
    btn.disabled = false;
    btn.textContent = 'Verificar →';
  }
});

function renderResult(d) {
  if (d.error) {
    result.innerHTML = `<div style="padding:1rem;border:1px solid var(--accent);color:var(--accent);font-family:'IBM Plex Mono',monospace;font-size:0.9rem;">✗ ${d.error}</div>`;
    return;
  }

  const summaryClass = d.canReceive === false ? 'style="border-color:var(--accent);"' : '';
  let html = `<div ${summaryClass} style="padding:1.3rem;border:1px solid var(--rule);background:rgba(178,36,31,0.03);margin-bottom:1.5rem;font-family:'Playfair Display',serif;font-size:1.15rem;line-height:1.4;">${d.summary}</div>`;

  html += '<div style="border-top:2px solid var(--ink);padding-top:1rem;">';
  html += '<div style="font-family:\'IBM Plex Mono\',monospace;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--accent);margin-bottom:1rem;">Detalle técnico</div>';

  for (const c of d.checks) {
    const mark = c.ok === true ? '✓' : c.ok === false ? '✗' : '?';
    const color = c.ok === true ? 'var(--ink)' : c.ok === false ? 'var(--accent)' : 'var(--ink-muted)';
    html += `<div style="display:grid;grid-template-columns:24px 80px 1fr;gap:0.8rem;padding:0.7rem 0;border-bottom:1px solid var(--rule-soft);align-items:start;">
      <span style="color:${color};font-weight:700;font-size:1rem;">${mark}</span>
      <span style="font-family:'IBM Plex Mono',monospace;font-size:0.78rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--ink-muted);">${c.label}</span>
      <span style="font-size:0.88rem;color:var(--ink-dim);line-height:1.45;">${c.detail}</span>
    </div>`;
  }
  html += '</div>';

  html += `<div style="margin-top:2rem;padding:1.2rem;border:1px dashed var(--rule-soft);font-size:0.9rem;color:var(--ink-dim);line-height:1.5;">
    ¿Algo salió mal? Esto es justo lo que resuelvo para negocios — verificación, configuración, y correo que de verdad llega. <a href="/#contacto" style="color:var(--accent);">Hablemos →</a>
  </div>`;

  result.innerHTML = html;
}
</script>
