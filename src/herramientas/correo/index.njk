<script>
const form = document.getElementById('correo-form');
const result = document.getElementById('result');
const btn = form.querySelector('button');

form.addEventListener('submit', async (e) => {
  e.preventDefault();
  const domain = document.getElementById('domain').value.trim();
  if (!domain) return;

  btn.disabled = true;
  btn.textContent = 'Verificando…';
  result.innerHTML = '<div style="font-family:\'IBM Plex Mono\',monospace;font-size:0.85rem;color:var(--ink-muted);padding:1rem 0;">Consultando DNS…</div>';

  try {
    const res = await fetch('/api/correo', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ domain }),
    });
    const data = await res.json();
    renderResult(data);
  } catch (err) {
    result.innerHTML = '<div class="result-error">No pude completar la verificación. Intenta de nuevo.</div>';
  } finally {
    btn.disabled = false;
    btn.textContent = 'Verificar →';
  }
});

function renderResult(d) {
  if (d.error) {
    result.innerHTML = `<div class="result-error">✗ ${d.error}</div>`;
    return;
  }

  const failClass = d.canReceive === false ? ' fail' : '';
  let html = `<div class="result-summary${failClass}">${d.summary}</div>`;

  html += '<div class="result-section">';
  html += '<div class="result-section-label">Detalle técnico</div>';

  for (const c of d.checks) {
    const mark = c.ok === true ? '✓' : c.ok === false ? '✗' : '?';
    const markClass = c.ok === true ? 'ok' : c.ok === false ? 'fail' : 'unknown';
    html += `<div class="result-check">
      <span class="mark ${markClass}">${mark}</span>
      <span class="label">${c.label}</span>
      <span class="detail">${c.detail}</span>
    </div>`;
  }
  html += '</div>';

  html += `<div class="result-cta">
    ¿Algo salió mal? Esto es justo lo que resuelvo para negocios — verificación, configuración, y correo que de verdad llega. <a href="/#contacto">Hablemos →</a>
  </div>`;

  result.innerHTML = html;
}
</script>
